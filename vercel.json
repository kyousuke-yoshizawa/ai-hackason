{
  "rewrites": [
    { "source": "/api/(auth|users|stores|likes|reviews|health)(/.*)?", "destination": "/api" },
    { "source": "/api/reservations(/.*)?", "destination": "/api/reservations" },
    { "source": "/api/crowd(/.*)?", "destination": "/api/crowd" },
    { "source": "/api/errors(/.*)?", "destination": "/api/errors" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/plan/generate.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/aggregate-crowd-analytics",
      "schedule": "0 14 * * *"
    }
  ]
}
