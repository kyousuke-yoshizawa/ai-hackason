# Supabase 設定（フロントエンド）
# https://supabase.com/dashboard から取得
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key（サーバー専用・VITE_ プレフィックスを付けないこと）
# Vercel Serverless Functions (api/) からのみ使用。RLS をバイパスするため絶対にフロントに公開しない。
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# API 設定（今後使用予定）
# VITE_API_URL=http://localhost:3000

# SendGrid（メール配信基盤 / Issue #24, api/_lib/email/ から使用）
# SMTP経由でSendGridに送信（nodemailer）。ユーザー名は固定で "apikey"。
SENDGRID_API_KEY=SG.your-sendgrid-api-key
EMAIL_FROM_ADDRESS=notify@ai-hackason.example
EMAIL_FROM_NAME=AI Hackathon 混雑通知

# 定期実行・ボタンリンク（Issue #25, api/_lib/cron/, api/crowd/report.ts から使用）
# メールのボタンリンク（/api/crowd/report）に埋め込む1回限りトークンの署名用シークレット
LINK_TOKEN_SECRET=change-me-to-a-long-random-string
# Vercel Cron からの呼び出しを認証するシークレット（Vercelが自動でAuthorizationヘッダに設定）
CRON_SECRET=change-me-to-a-long-random-string
# ボタンリンクURLの組み立てに使うアプリの公開ベースURL
APP_BASE_URL=https://ai-hackason.vercel.app
