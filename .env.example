# Supabase 設定（フロントエンド）
# https://supabase.com/dashboard から取得
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# API 設定（今後使用予定）
# VITE_API_URL=http://localhost:3000

# --- サーバー側（server/）専用の環境変数 ---
# Supabase service_role キー（バックエンドのみで使用。フロントに含めないこと）
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# SendGrid（メール配信基盤 / Issue #24）
SENDGRID_API_KEY=SG.your-sendgrid-api-key
EMAIL_FROM_ADDRESS=notify@ai-hackason.example
EMAIL_FROM_NAME=AI Hackathon 混雑通知

# サーバーのポート
PORT=3000
