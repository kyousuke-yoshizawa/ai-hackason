# Supabase 設定（バックエンド専用）
# https://supabase.com/dashboard から取得
# T08でフロントの直接Supabaseアクセスを廃止（すべてREST経由に統一）したため、
# フロントエンドはSupabase資格情報を一切必要としない。VITE_ プレフィックスは
# backend/db.ts が process.env から読む際の historical な命名で、Viteのビルド時
# 埋め込み対象ではない（サーバー専用の環境変数として扱うこと）。
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key（サーバー専用・VITE_ プレフィックスを付けないこと）
# Express バックエンド（server/）・Vercel Serverless Functions (api/) からのみ使用。RLS をバイパスするため絶対にフロントに公開しない。
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# ローカルExpressサーバー（server/index.ts、npm run server）のリスンポート
PORT=3000

# Express（server/app.ts）のCORS許可オリジン（カンマ区切りで複数可）
# 未設定時は http://localhost:5173（Vite開発サーバー）のみ許可。
# 本番はVercelの自ドメイン（例: https://ai-hackason.vercel.app）を設定する。
# CORS_ALLOWED_ORIGINS=http://localhost:5173

# フロントエンドのAPI接続先（src/lib/api.ts）
# 未設定時は http://localhost:3000 にフォールバックするため、ローカル開発では通常不要。
# フロントとバックエンドを別オリジンにデプロイする場合のみ設定する。
# VITE_API_URL=http://localhost:3000

# SendGrid（メール配信基盤 / Issue #24, backend/domains/email/ から使用）
# SMTP経由でSendGridに送信（nodemailer）。ユーザー名は固定で "apikey"。
SENDGRID_API_KEY=SG.your-sendgrid-api-key
EMAIL_FROM_ADDRESS=notify@ai-hackason.example
EMAIL_FROM_NAME=AI Hackathon 混雑通知

# Claude API（プラン生成 / T12, backend/domains/plan/claudeClient.ts から使用）
# https://console.anthropic.com/settings/keys から取得。本番はチーム共有キーをVercelの
# 環境変数に設定する（インフラ担当が管理。キーをコードや.envにコミットしないこと）
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
# モデルIDを上書きする場合のみ設定（未設定時は claude-sonnet-5 を使用）
# ANTHROPIC_MODEL=claude-sonnet-5
# ローカル開発でANTHROPIC_API_KEYが無い場合に設定すると、Claude APIを呼ばず
# 固定のモックプラン（backend/domains/plan/mockResponse.ts）を返す（Issue #121）。
# 本番（Vercelの環境変数）には絶対に設定しないこと
# PLAN_MOCK=1

# 定期実行・ボタンリンク（Issue #25, backend/domains/notifications/, api/crowd/report.ts から使用）
# メールのボタンリンク（/api/crowd/report）に埋め込む1回限りトークンの署名用シークレット
LINK_TOKEN_SECRET=change-me-to-a-long-random-string
# Vercel Cron からの呼び出しを認証するシークレット（Vercelが自動でAuthorizationヘッダに設定）
CRON_SECRET=change-me-to-a-long-random-string
# ボタンリンクURLの組み立てに使うアプリの公開ベースURL
APP_BASE_URL=https://ai-hackason.vercel.app
